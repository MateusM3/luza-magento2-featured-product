<?php

/** @var \Magento\Framework\View\Element\Template $block */
/** @var \Luza\FeaturedProduct\ViewModel\FeaturedProductData $viewModel */
/** @var \Magento\Framework\Escaper $escaper */
$viewModel = $block->getData('view_model');

if (!$viewModel->hasProduct()) {
    return;
}

$imageUrl = $viewModel->getImageUrl();
$name = $viewModel->getName();
?>
<a class="luza-featured-product"
   href="<?= $escaper->escapeUrl($viewModel->getProductUrl()) ?>"
   data-product-id="<?= (int) $viewModel->getProductId() ?>"
   aria-label="<?= $escaper->escapeHtmlAttr(__('Featured product: %1', $name)) ?>">
    <span class="luza-featured-product__figure">
        <span class="luza-featured-product__badge"><?= $escaper->escapeHtml(__('Featured')) ?></span>
        <?php if ($imageUrl !== ''): ?>
            <img class="luza-featured-product__image"
                 src="<?= $escaper->escapeUrl($imageUrl) ?>"
                 alt="<?= $escaper->escapeHtmlAttr($name) ?>"
                 loading="lazy"/>
        <?php endif; ?>
    </span>

    <span class="luza-featured-product__body">
        <span class="luza-featured-product__title"><?= $escaper->escapeHtml($name) ?></span>

        <span class="luza-featured-product__price"><?= $viewModel->getPrice() ?></span>

        <span class="luza-featured-product__stock">
            <span class="luza-featured-product__stock-label"><?= $escaper->escapeHtml(__('Available stock')) ?>:</span>
            <span class="luza-featured-product__stock-value"
                  data-role="featured-product-stock"><?= $escaper->escapeHtml((string) $viewModel->getStock()) ?></span>
            <span class="luza-featured-product__stock-unit"><?= $escaper->escapeHtml(__('un.')) ?></span>
        </span>

        <span class="luza-featured-product__cta">
            <?= $escaper->escapeHtml(__('View product')) ?>
            <span class="luza-featured-product__cta-arrow" aria-hidden="true">&rarr;</span>
        </span>
    </span>
</a>
