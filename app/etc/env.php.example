<?php
/**
 * Example Magento environment file for the Docker development stack.
 *
 * `app/etc/env.php` is generated by `bin/magento setup:install` and is git-ignored
 * (it holds the encryption key). Use this file as a reference of the expected shape.
 *
 * To reuse it directly instead of reinstalling:
 *   1) cp app/etc/env.php.example app/etc/env.php
 *   2) replace every CHANGE_ME_* placeholder (the crypt key MUST be unique)
 *   3) bin/magento setup:upgrade && bin/magento cache:flush
 *
 * DB host/name/user/password already match docker-compose.yml defaults.
 */
return [
    'backend' => [
        'frontName' => 'admin'
    ],
    'cache' => [
        'graphql' => [
            'id_salt' => 'CHANGE_ME_RANDOM_32_CHARS'
        ],
        'frontend' => [
